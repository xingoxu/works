<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=Edge">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#ffffff">
  <title>{{ title }} | xingo&#39;s works</title>
  <meta name="description" content="{{ description }}">
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:url" content="https://works.xingoxu.com/">
  <meta property="og:site_name" content="xingo's works">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:updated_time" content="{{toISOString updateDate}}">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ title }}">
  <meta name="twitter:description" content="{{ description }}">
  <link rel="icon" href="https://blog.xingoxu.com/favicon.ico">
  <link rel="stylesheet" href="{{ stylesheetHref }}">
</head>
<body>
  <div class="layout">
    <header class="site-header">
      <div>
        <a class="site-title" href="/">xingo's works</a>
        <p class="site-tagline">一些项目与实验的存档。</p>
      </div>
      <nav class="site-nav" aria-label="Primary">
        <a href="https://blog.xingoxu.com/">主页</a>
        <a href="https://blog.xingoxu.com/archives">归档</a>
        <a href="https://blog.xingoxu.com/about">关于</a>
      </nav>
    </header>

    <main class="content">
      <div class="page-meta">
        <time datetime="{{toISOString updateDate}}">最近更新：{{formatDate updateDate}}</time>
      </div>
      <h1 class="page-title">{{ title }}</h1>
      <article class="article-entry" itemprop="articleBody">
        {{{ articleEntry }}}
      </article>
    </main>

    <footer class="site-footer">
      <span>&copy; xingo</span>
      <span><a href="https://github.com/xingoxu/works" target="_blank" rel="noopener noreferrer">GitHub</a></span>
    </footer>
  </div>
</body>
</html>
